NODE_ENV=development
LOGGING_DEBUG=true
DEBUG_REQUESTS=true
AI_DEBUG_LOGS=true

PORT=3000
HOST=0.0.0.0

AI_PLATFORM=Openrouter
API_KEY=
API_URL=https://openrouter.ai/api/v1/chat/completions
AI_DEFAULT_MODEL=x-ai/grok-4.1-fast

# Image Generation (Together AI)
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_IMAGE_API_URL=https://api.together.xyz/v1/images/generations
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.2-dev

# now using for image genereation
XAI_API_KEY=

# Security (used for sessions)
JWT_SECRET=your_jwt_secret_at_least_32_chars_long


